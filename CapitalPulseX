  const startupCards = document.querySelectorAll('#startupGrid .news-card');
  startupCards.forEach((card, i) => {
    if (startupNews[i]) card.onclick = () => openArticle(startupNews[i]);
  });

  setInterval(updateTime, 1000);
  setInterval(simulateLivePriceUpdate, 8000);
  setInterval(checkScheduledUpdates, 1000);
  updateTime();

  // Initial welcome toast
  setTimeout(() => showToast('Markets open — All data live & refreshed', 'CapitalPulseX'), 1500);

  // Animate cards in
  document.querySelectorAll('.news-card, .paper-card, .quantum-card').forEach((el, i) => {
    el.style.animationDelay = `${i * 0.04}s`;
    el.style.animation = 'fadeInUp 0.5s ease both';
  });
}

