<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>CapitalPulseX — Markets · Business · Technology · Research</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,600;0,700;0,900;1,400;1,700&family=Space+Grotesk:wght@300;400;500;600;700&family=Space+Mono:wght@400;700&display=swap" rel="stylesheet">
<style>
  :root {
    --bg-primary: #060610;
    --bg-secondary: #0c0c1e;
    --bg-card: #0f0f22;
    --bg-card2: #12122a;
    --border: rgba(255,255,255,0.07);
    --border-accent: rgba(0,120,255,0.3);
    --blue: #0078FF;
    --blue-bright: #3399FF;
    --blue-glow: rgba(0,120,255,0.15);
    --gold: #C9A84C;
    --gold-light: #E8C97E;
    --red: #FF3B5C;
    --green: #00D084;
    --white: #F5F5FF;
    --muted: rgba(245,245,255,0.45);
    --muted2: rgba(245,245,255,0.2);
    --font-display: 'Playfair Display', Georgia, serif;
    --font-body: 'Space Grotesk', sans-serif;
    --font-mono: 'Space Mono', monospace;
    --ticker-speed: 45s;
  }

  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  html { scroll-behavior: smooth; }

  body {
    background: var(--bg-primary);
    color: var(--white);
    font-family: var(--font-body);
    font-size: 15px;
    line-height: 1.6;
    overflow-x: hidden;
  }

  /* ── SCROLLBAR ── */
  ::-webkit-scrollbar { width: 5px; }
  ::-webkit-scrollbar-track { background: var(--bg-primary); }
  ::-webkit-scrollbar-thumb { background: var(--blue); border-radius: 3px; }

  /* ── ANIMATIONS ── */
  @keyframes fadeInUp {
    from { opacity: 0; transform: translateY(24px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  @keyframes shimmer {
    0%   { background-position: -800px 0; }
    100% { background-position: 800px 0; }
  }
  @keyframes tickerScroll {
    0%   { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }
  @keyframes pulse {
    0%, 100% { opacity: 1; }
    50%       { opacity: 0.4; }
  }
  @keyframes glow {
    0%, 100% { box-shadow: 0 0 12px rgba(0,120,255,0.4); }
    50%       { box-shadow: 0 0 28px rgba(0,120,255,0.8); }
  }
  @keyframes scanline {
    0%   { transform: translateY(-100%); }
    100% { transform: translateY(100vh); }
  }
  @keyframes spin { to { transform: rotate(360deg); } }

  /* ── SCANLINE OVERLAY ── */
  body::before {
    content: '';
    position: fixed;
    inset: 0;
    background: repeating-linear-gradient(0deg, transparent, transparent 2px, rgba(0,0,0,0.03) 2px, rgba(0,0,0,0.03) 4px);
    pointer-events: none;
    z-index: 9999;
  }

  /* ── TOP ANNOUNCEMENT BAR ── */
  .announcement-bar {
    background: linear-gradient(90deg, #001033, #000822, #001033);
    border-bottom: 1px solid var(--border-accent);
    padding: 7px 20px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--muted);
  }
  .announcement-bar .live-dot {
    width: 7px; height: 7px;
    background: var(--green);
    border-radius: 50%;
    display: inline-block;
    margin-right: 6px;
    animation: pulse 1.5s ease-in-out infinite;
  }
  .announcement-bar .update-time { color: var(--gold); font-weight: 700; }

  /* ── HEADER ── */
  header {
    position: sticky;
    top: 0;
    z-index: 1000;
    background: rgba(6,6,16,0.97);
    backdrop-filter: blur(20px);
    border-bottom: 1px solid var(--border);
  }
  .header-main {
    max-width: 1440px;
    margin: 0 auto;
    padding: 0 24px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 68px;
    gap: 24px;
  }
  .logo {
    font-family: var(--font-display);
    font-size: 26px;
    font-weight: 900;
    letter-spacing: -0.5px;
    text-decoration: none;
    display: flex;
    align-items: center;
    gap: 0;
    white-space: nowrap;
  }
  .logo .Capital { color: var(--white); }
  .logo .Pulse { color: var(--blue-bright); }
  .logo .X {
    color: var(--gold);
    font-style: italic;
    font-size: 30px;
    margin-left: 2px;
  }
  .logo-icon {
    width: 32px; height: 32px;
    background: var(--blue);
    border-radius: 6px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-right: 10px;
    animation: glow 3s ease-in-out infinite;
    flex-shrink: 0;
  }
  .logo-icon svg { width: 18px; height: 18px; fill: none; stroke: white; stroke-width: 2; }

  .header-actions { display: flex; align-items: center; gap: 10px; }

  .header-search {
    display: flex;
    align-items: center;
    gap: 8px;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 7px 14px;
    transition: border-color 0.2s;
  }
  .header-search:focus-within { border-color: var(--blue); }
  .header-search input {
    background: none;
    border: none;
    outline: none;
    color: var(--white);
    font-family: var(--font-body);
    font-size: 13px;
    width: 200px;
  }
  .header-search input::placeholder { color: var(--muted); }
  .header-search svg { width: 14px; height: 14px; stroke: var(--muted); fill: none; flex-shrink: 0; }

  .btn-primary {
    background: var(--blue);
    color: white;
    border: none;
    border-radius: 8px;
    padding: 8px 20px;
    font-family: var(--font-body);
    font-size: 13px;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.2s;
    letter-spacing: 0.3px;
  }
  .btn-primary:hover { background: var(--blue-bright); transform: translateY(-1px); }

  .btn-ghost {
    background: none;
    color: var(--muted);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 8px 16px;
    font-family: var(--font-body);
    font-size: 13px;
    cursor: pointer;
    transition: all 0.2s;
  }
  .btn-ghost:hover { color: var(--white); border-color: var(--blue); }

  /* ── NAV ── */
  .nav-strip {
    background: var(--bg-secondary);
    border-bottom: 1px solid var(--border);
    overflow-x: auto;
    scrollbar-width: none;
  }
  .nav-strip::-webkit-scrollbar { display: none; }
  .nav-inner {
    max-width: 1440px;
    margin: 0 auto;
    padding: 0 24px;
    display: flex;
    align-items: center;
    gap: 0;
    height: 46px;
  }
  .nav-item {
    padding: 0 16px;
    height: 46px;
    display: flex;
    align-items: center;
    font-size: 13px;
    font-weight: 500;
    color: var(--muted);
    cursor: pointer;
    white-space: nowrap;
    border-bottom: 2px solid transparent;
    transition: all 0.2s;
    text-decoration: none;
  }
  .nav-item:hover, .nav-item.active {
    color: var(--white);
    border-bottom-color: var(--blue);
  }
  .nav-item.active { color: var(--blue-bright); }

  /* ── TICKER ── */
  .ticker-wrap {
    background: #030318;
    border-bottom: 1px solid var(--border-accent);
    overflow: hidden;
    padding: 0;
    height: 36px;
    display: flex;
    align-items: center;
  }
  .ticker-label {
    background: var(--blue);
    color: white;
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 700;
    padding: 0 14px;
    height: 100%;
    display: flex;
    align-items: center;
    flex-shrink: 0;
    letter-spacing: 1px;
    z-index: 2;
  }
  .ticker-inner {
    display: flex;
    animation: tickerScroll var(--ticker-speed) linear infinite;
    gap: 0;
    will-change: transform;
  }
  .ticker-item {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 0 28px;
    font-family: var(--font-mono);
    font-size: 12px;
    white-space: nowrap;
    border-right: 1px solid var(--border);
  }
  .ticker-item .sym { color: var(--muted); font-weight: 700; font-size: 11px; letter-spacing: 0.5px; }
  .ticker-item .price { color: var(--white); font-weight: 700; }
  .ticker-item .chg.up { color: var(--green); }
  .ticker-item .chg.down { color: var(--red); }

  /* ── MAIN LAYOUT ── */
  .main-container {
    max-width: 1440px;
    margin: 0 auto;
    padding: 0 24px;
  }

  /* ── HERO ── */
  .hero-section {
    padding: 32px 0 24px;
    border-bottom: 1px solid var(--border);
    animation: fadeInUp 0.6s ease both;
  }
  .hero-grid {
    display: grid;
    grid-template-columns: 1fr 1fr 320px;
    gap: 1px;
    background: var(--border);
  }
  .hero-main {
    background: var(--bg-primary);
    padding: 28px;
    cursor: pointer;
    transition: background 0.2s;
    position: relative;
    overflow: hidden;
  }
  .hero-main::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 3px;
    background: linear-gradient(90deg, var(--blue), var(--gold));
  }
  .hero-main:hover { background: var(--bg-card); }
  .hero-main .category-tag {
    font-family: var(--font-mono);
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 2px;
    color: var(--blue-bright);
    text-transform: uppercase;
    margin-bottom: 14px;
    display: flex;
    align-items: center;
    gap: 8px;
  }
  .hero-main h1 {
    font-family: var(--font-display);
    font-size: 34px;
    font-weight: 700;
    line-height: 1.2;
    color: var(--white);
    margin-bottom: 14px;
    letter-spacing: -0.5px;
  }
  .hero-main .hero-excerpt {
    color: var(--muted);
    font-size: 15px;
    line-height: 1.65;
    margin-bottom: 18px;
  }
  .hero-meta {
    display: flex;
    align-items: center;
    gap: 12px;
    font-size: 12px;
    color: var(--muted2);
    font-family: var(--font-mono);
  }
  .hero-meta .author { color: var(--gold); }
  .hero-meta .dot { opacity: 0.4; }

  .hero-secondary {
    background: var(--bg-primary);
    display: flex;
    flex-direction: column;
    gap: 1px;
  }
  .hero-secondary-item {
    background: var(--bg-card);
    padding: 22px 24px;
    cursor: pointer;
    flex: 1;
    transition: background 0.2s;
    border-left: 1px solid var(--border);
  }
  .hero-secondary-item:hover { background: var(--bg-card2); }
  .hero-secondary-item .cat { font-size: 10px; font-family: var(--font-mono); letter-spacing: 2px; text-transform: uppercase; color: var(--gold); margin-bottom: 8px; }
  .hero-secondary-item h3 { font-family: var(--font-display); font-size: 17px; font-weight: 600; line-height: 1.3; margin-bottom: 8px; }
  .hero-secondary-item p { font-size: 13px; color: var(--muted); line-height: 1.5; }

  .hero-sidebar {
    background: var(--bg-card);
    border-left: 1px solid var(--border);
  }
  .sidebar-panel-title {
    padding: 16px 20px;
    font-family: var(--font-mono);
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--muted);
    border-bottom: 1px solid var(--border);
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  /* ── MARKETS PANEL ── */
  .market-item {
    padding: 12px 20px;
    border-bottom: 1px solid var(--border);
    display: flex;
    align-items: center;
    justify-content: space-between;
    cursor: pointer;
    transition: background 0.2s;
  }
  .market-item:hover { background: var(--bg-card2); }
  .market-item .m-name { font-size: 13px; font-weight: 600; }
  .market-item .m-sub { font-size: 11px; color: var(--muted); font-family: var(--font-mono); }
  .market-item .m-price { font-family: var(--font-mono); font-size: 14px; font-weight: 700; }
  .market-item .m-chg { font-family: var(--font-mono); font-size: 12px; padding: 2px 7px; border-radius: 4px; }
  .m-chg.up { color: var(--green); background: rgba(0,208,132,0.12); }
  .m-chg.down { color: var(--red); background: rgba(255,59,92,0.12); }
  .market-item .m-right { text-align: right; }

  /* ── SECTION HEADINGS ── */
  .section-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 28px 0 18px;
    border-bottom: 1px solid var(--border);
    margin-bottom: 20px;
  }
  .section-title {
    font-family: var(--font-display);
    font-size: 24px;
    font-weight: 700;
    display: flex;
    align-items: center;
    gap: 12px;
  }
  .section-title .line {
    width: 4px; height: 24px;
    background: var(--blue);
    border-radius: 2px;
  }
  .section-title .line.gold { background: var(--gold); }
  .section-title .line.red { background: var(--red); }
  .section-title .line.green { background: var(--green); }
  .see-all { font-size: 13px; color: var(--blue-bright); cursor: pointer; font-weight: 500; text-decoration: none; }
  .see-all:hover { color: var(--white); }

  /* ── NEWS GRID ── */
  .two-col { display: grid; grid-template-columns: 1fr 320px; gap: 32px; padding: 28px 0; }
  .news-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1px; background: var(--border); margin-bottom: 1px; }
  .news-card {
    background: var(--bg-card);
    padding: 22px;
    cursor: pointer;
    transition: all 0.22s;
    position: relative;
    overflow: hidden;
  }
  .news-card::after {
    content: '';
    position: absolute;
    bottom: 0; left: 0; right: 0;
    height: 2px;
    background: var(--blue);
    transform: scaleX(0);
    transition: transform 0.2s;
    transform-origin: left;
  }
  .news-card:hover { background: var(--bg-card2); }
  .news-card:hover::after { transform: scaleX(1); }
  .news-card .nc-cat {
    font-size: 10px;
    font-family: var(--font-mono);
    font-weight: 700;
    letter-spacing: 2px;
    text-transform: uppercase;
    margin-bottom: 10px;
  }
  .nc-cat.blue { color: var(--blue-bright); }
  .nc-cat.gold { color: var(--gold); }
  .nc-cat.red { color: var(--red); }
  .nc-cat.green { color: var(--green); }
  .news-card h3 {
    font-family: var(--font-display);
    font-size: 18px;
    font-weight: 600;
    line-height: 1.3;
    margin-bottom: 10px;
    color: var(--white);
  }
  .news-card p { font-size: 13px; color: var(--muted); line-height: 1.55; margin-bottom: 14px; }
  .nc-meta { font-size: 11px; color: var(--muted2); font-family: var(--font-mono); display: flex; align-items: center; gap: 8px; }
  .nc-meta .nc-author { color: var(--gold-light); }

  /* ── FEATURED WIDE ── */
  .news-card.wide { grid-column: span 2; }
  .news-card.wide h3 { font-size: 22px; }

  /* ── RESEARCH PAPERS ── */
  .paper-card {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 22px;
    cursor: pointer;
    transition: all 0.22s;
    margin-bottom: 12px;
    display: flex;
    gap: 18px;
    align-items: flex-start;
  }
  .paper-card:hover { border-color: var(--blue); background: var(--bg-card2); transform: translateX(4px); }
  .paper-num {
    font-family: var(--font-mono);
    font-size: 28px;
    font-weight: 700;
    color: var(--blue);
    opacity: 0.3;
    min-width: 40px;
    line-height: 1;
    padding-top: 2px;
  }
  .paper-body h4 { font-family: var(--font-display); font-size: 17px; font-weight: 600; line-height: 1.3; margin-bottom: 7px; }
  .paper-body p { font-size: 13px; color: var(--muted); line-height: 1.5; margin-bottom: 10px; }
  .paper-tags { display: flex; gap: 6px; flex-wrap: wrap; }
  .ptag {
    background: var(--bg-primary);
    border: 1px solid var(--border);
    color: var(--muted);
    font-size: 10px;
    padding: 3px 9px;
    border-radius: 20px;
    font-family: var(--font-mono);
    letter-spacing: 0.5px;
  }
  .ptag.blue { border-color: var(--blue); color: var(--blue-bright); }
  .ptag.gold { border-color: var(--gold); color: var(--gold); }

  /* ── SIDEBAR ── */
  .sidebar { position: relative; }
  .sidebar-sticky { position: sticky; top: 130px; }
  .sidebar-widget {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 10px;
    margin-bottom: 20px;
    overflow: hidden;
  }
  .sw-title {
    padding: 14px 18px;
    font-family: var(--font-mono);
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--muted);
    border-bottom: 1px solid var(--border);
    background: var(--bg-card2);
    display: flex;
    align-items: center;
    gap: 8px;
  }
  .sw-item {
    padding: 13px 18px;
    border-bottom: 1px solid var(--border);
    cursor: pointer;
    transition: background 0.15s;
    display: flex;
    align-items: flex-start;
    gap: 10px;
  }
  .sw-item:last-child { border-bottom: none; }
  .sw-item:hover { background: var(--bg-card2); }
  .sw-rank {
    font-family: var(--font-mono);
    font-size: 18px;
    font-weight: 700;
    color: var(--blue);
    opacity: 0.4;
    min-width: 22px;
    line-height: 1.2;
  }
  .sw-item p { font-size: 13px; line-height: 1.4; font-weight: 500; }
  .sw-item .sw-meta { font-size: 11px; color: var(--muted); margin-top: 3px; font-family: var(--font-mono); }

  /* ── COMPANIES ROW ── */
  .companies-row {
    display: flex;
    gap: 1px;
    background: var(--border);
    overflow-x: auto;
    scrollbar-width: none;
  }
  .company-card {
    background: var(--bg-card);
    padding: 20px 24px;
    min-width: 200px;
    cursor: pointer;
    flex: 1;
    transition: background 0.2s;
  }
  .company-card:hover { background: var(--bg-card2); }
  .company-card .co-name { font-weight: 700; font-size: 15px; margin-bottom: 4px; }
  .company-card .co-type { font-size: 11px; color: var(--muted); font-family: var(--font-mono); margin-bottom: 10px; letter-spacing: 0.5px; }
  .company-card .co-price { font-family: var(--font-mono); font-size: 20px; font-weight: 700; }
  .company-card .co-chg { font-size: 12px; font-family: var(--font-mono); }

  /* ── CATEGORY BADGES ── */
  .badge {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    font-size: 10px;
    font-family: var(--font-mono);
    font-weight: 700;
    letter-spacing: 1px;
    text-transform: uppercase;
    padding: 4px 10px;
    border-radius: 4px;
    margin-bottom: 6px;
  }
  .badge.breaking { background: rgba(255,59,92,0.15); color: var(--red); border: 1px solid rgba(255,59,92,0.3); }
  .badge.live { background: rgba(0,208,132,0.12); color: var(--green); border: 1px solid rgba(0,208,132,0.3); }
  .badge.ai { background: rgba(0,120,255,0.12); color: var(--blue-bright); border: 1px solid var(--border-accent); }
  .badge.exclusive { background: rgba(201,168,76,0.15); color: var(--gold); border: 1px solid rgba(201,168,76,0.3); }

  /* ── DIVIDER ── */
  .divider { height: 1px; background: var(--border); margin: 0; }

  /* ── FOOTER ── */
  footer {
    background: var(--bg-secondary);
    border-top: 1px solid var(--border);
    padding: 40px 24px 24px;
    margin-top: 60px;
  }
  .footer-inner { max-width: 1440px; margin: 0 auto; }
  .footer-top { display: grid; grid-template-columns: 280px repeat(4,1fr); gap: 32px; padding-bottom: 32px; border-bottom: 1px solid var(--border); }
  .footer-brand p { color: var(--muted); font-size: 13px; line-height: 1.6; margin-top: 12px; }
  .footer-col h5 { font-size: 11px; font-family: var(--font-mono); font-weight: 700; letter-spacing: 2px; text-transform: uppercase; color: var(--muted); margin-bottom: 14px; }
  .footer-col a { display: block; color: var(--muted); font-size: 13px; margin-bottom: 8px; text-decoration: none; transition: color 0.15s; }
  .footer-col a:hover { color: var(--white); }
  .footer-bottom { padding-top: 20px; display: flex; justify-content: space-between; align-items: center; font-size: 12px; color: var(--muted2); font-family: var(--font-mono); }
  .footer-bottom .copyright span { color: var(--blue-bright); }

  /* ── UPDATE INDICATOR ── */
  .update-toast {
    position: fixed;
    top: 90px;
    right: 20px;
    background: var(--bg-card2);
    border: 1px solid var(--border-accent);
    border-radius: 10px;
    padding: 14px 18px;
    font-size: 13px;
    z-index: 2000;
    transform: translateX(120%);
    transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1);
    max-width: 280px;
  }
  .update-toast.show { transform: translateX(0); }
