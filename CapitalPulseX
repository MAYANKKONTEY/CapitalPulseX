// ════════════════════════════════════════════════════
// ARTICLE MODAL
// ════════════════════════════════════════════════════

function openArticle(article) {
  if (!article) return;
  document.getElementById('modalCat').textContent = article.cat || 'NEWS';
  document.getElementById('modalTitle').textContent = article.title || '';
  document.getElementById('modalByline').innerHTML = `By <span>${article.author || 'Staff Reporter'}</span> · ${article.date || 'Today'} · ${article.readTime || '5 min read'}`;
  document.getElementById('modalLead').textContent = article.lead || '';
  document.getElementById('modalBody').innerHTML = article.body || '<p>Full article content available.</p>';
  document.getElementById('articleModal').classList.add('open');
  document.body.style.overflow = 'hidden';
}

function closeArticle() {
  document.getElementById('articleModal').classList.remove('open');
  document.body.style.overflow = '';
}

function handleModalClick(e) {
  if (e.target === document.getElementById('articleModal')) closeArticle();
}

document.addEventListener('keydown', e => { if (e.key === 'Escape') closeArticle(); });

